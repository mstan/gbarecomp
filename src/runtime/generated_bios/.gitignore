# Real BIOS-recomp output is generated by `gba_recompile --bios` and
# must not be committed (it embeds Nintendo's BIOS bytes as
# instruction-by-instruction lowerings).
bios_recompiled.cpp
bios_recompiled.h

# Likewise BIOS-derived: the address->name symbol table, emitted by
# `gba_recompile --bios` alongside bios_recompiled.cpp. Regenerate locally.
bios_symbol_map.cpp

# bios_dispatch_table.cpp is committed for provenance and overwritten by BIOS
# regeneration. Clean builds use bios_dispatch_stub.cpp until the matching
# ignored bios_recompiled.cpp is present.
