# Real BIOS-recomp output is generated by `gba_recompile --bios` and
# must not be committed (it embeds Nintendo's BIOS bytes as
# instruction-by-instruction lowerings).
bios_recompiled.cpp
bios_recompiled.h

# bios_dispatch_table.cpp IS committed as a placeholder so the build
# works without BIOS regen. gba_recompile --bios overwrites it.
